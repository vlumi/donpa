      }
    },
    "This clears your high scores and career stats on this device. Boards unlocked through play lock again." : {
      "localizations" : {
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tämä tyhjentää ennätykset ja uratilastot tältä laitteelta. Pelaamalla avatut kentät lukittuvat uudelleen."
          }
        },
        "ja" : {
          "stringUnit" : {
