    "That link or code isn't a valid Donpa share." : {
      "comment" : "A loud alert message for a share that failed to verify.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Linkki tai koodi ei ole kelvollinen Donpa-jako."
