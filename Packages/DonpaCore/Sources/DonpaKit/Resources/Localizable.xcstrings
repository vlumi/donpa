    "Arrows move · Return digs · F flags — ⌘\/ for all shortcuts" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrows move · Return digs · F flags — ⌘\/ for all shortcuts"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuolet siirtävät · Return kaivaa · F liputtaa — ⌘\/ näyttää kaikki"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "矢印で移動 · Returnで掘る · Fで旗 — ⌘\/で一覧"
          }
        }
      }
    },
    "Arrows or WASD move the cursor, Enter digs, F flags, Space switches dig\/flag. Everything else works from the keyboard too — press ⌘\/ for the full reference." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrows or WASD move the cursor, Enter digs, F flags, Space switches dig\/flag. Everything else works from the keyboard too — press ⌘\/ for the full reference."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuolet tai WASD liikuttavat kohdistinta, Enter kaivaa, F liputtaa, välilyönti vaihtaa kaivuun ja liputuksen välillä. Kaikki muukin toimii näppäimistöltä – paina ⌘\/ nähdäksesi koko luettelon."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "矢印キーまたはWASDでカーソルを移動、Enterで掘り、Fで旗を立て、スペースで掘る／旗を切替。他の操作もすべてキーボードで使える——⌘\/で一覧を表示。"
          }
        }
      }
    },
