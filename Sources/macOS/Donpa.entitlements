<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Game Center, for the strictly opt-in decorations reporter (see
	     GameCenterReporter): GameKit is never touched until the player enables
	     it in the Decorations footer. -->
	<key>com.apple.developer.game-center</key>
	<true/>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)fi.misaki.donpa</string>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Nearby exchange (MultipeerConnectivity/Bonjour): the sandbox needs both
	     directions to advertise and browse on the local network. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- User-picked files, both directions: READ a picked image to scan a rival's
	     QR (.fileImporter), and WRITE the share-card PNG where the user chooses
	     (.fileExporter — with read-only, the save panel silently no-ops). -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!-- Universal Links for score sharing — see the iOS entitlements for the why. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:donpa.app</string>
	</array>
</dict>
</plist>
